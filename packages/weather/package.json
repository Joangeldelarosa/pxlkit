{
  "name": "@pxlkit/weather",
  "version": "1.0.1",
  "description": "Weather and nature icon pack for pxlkit — sun, rain, clouds, and more",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/joangeldelarosa/pxlkit",
    "directory": "packages/weather"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@pxlkit/core": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "pixel-art",
    "icons",
    "weather",
    "nature",
    "environment",
    "ui"
  ]
}
