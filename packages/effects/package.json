{
  "name": "@pxlkit/effects",
  "version": "1.0.1",
  "description": "Animated visual effect icons — explosions, signals, particles, glows, and VFX",
  "author": {
    "name": "Joangel De La Rosa",
    "url": "https://github.com/joangeldelarosa"
  },
  "repository": {
    "type": "git",
