{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@pxlkit/core": ["../../packages/core/src"],
      "@pxlkit/gamification": ["../../packages/gamification/src"],
      "@pxlkit/feedback": ["../../packages/feedback/src"],
      "@pxlkit/social": ["../../packages/social/src"],
      "@pxlkit/weather": ["../../packages/weather/src"],
      "@pxlkit/effects": ["../../packages/effects/src"],
      "@pxlkit/ui": ["../../packages/ui/src"],
      "@pxlkit/ui-kit": ["../../packages/ui-kit/src"],
      "@pxlkit/ui-kit/*": ["../../packages/ui-kit/src/*"],
      "@pxlkit/voxel": ["../../packages/voxel/src"],
      "@pxlkit/parallax": ["../../packages/parallax/src"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "preserve"
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  // src/app/ui-kit/sections + */metadata.generated.ts are emitted by
  // `npm run docs:build` but are NOT wired into the app (and not committed —
  // see .gitignore). Excluded so stray local generator output can never break
  // `next build` typechecking. The wired docs sections
  // (src/app/docs/sections) stay included and typechecked.
  "exclude": [
    "node_modules",
    "src/app/ui-kit/sections",
    "src/app/ui-kit/*/metadata.generated.ts"
  ]
}
